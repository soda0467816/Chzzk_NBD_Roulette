{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "난바다의 룰렛",
  "version": "0.1.0",
  "identifier": "com.nbdraw.roulette",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173/streamer.html",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "난바다의 룰렛",
        "url": "streamer.html",
        "width": 1440,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
